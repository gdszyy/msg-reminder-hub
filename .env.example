# ============================================================
# LLM 配置（支持 OpenAI 兼容接口）
# ============================================================
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# ============================================================
# Lark (Feishu) 应用凭证
# 在飞书开放平台 https://open.feishu.cn 创建企业自建应用后获取
# 需要开通权限：im:message:readonly, im:chat:readonly, im:message
# ============================================================
LARK_APP_ID=cli_xxxxxxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 域名类型："lark"（海外，默认）或 "feishu"（国内）
LARK_DOMAIN_TYPE=lark

# 被监控用户的 open_id（系统会识别与此用户相关的消息）
LARK_TARGET_USER_ID=ou_xxxxxxxxxxxxxxxx

# 需要监控的群组 chat_id 列表（逗号分隔，留空则监控所有已加入的群）
LARK_MONITORED_CHATS=

# ============================================================
# Telegram 配置
# ============================================================
TG_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TG_TARGET_USER_ID=123456789

# 需要监控的 Telegram 群组/频道 ID 列表（逗号分隔）
TG_MONITORED_CHATS=-1001234567890,-1009876543210

# ============================================================
# WhatsApp 配置（暂缓）
# ============================================================
# WA_API_TOKEN=
# WA_PHONE_NUMBER_ID=
# WA_TARGET_PHONE=

# ============================================================
# 数据库配置
# ============================================================
# SQLite（默认，适合单机部署）
DATABASE_URL=sqlite:///data/msg_reminder.db

# MySQL（生产环境推荐）
# DATABASE_URL=mysql+pymysql://user:pass@host:3306/msg_reminder

# ============================================================
# 调度配置
# ============================================================
# 消息拉取间隔（分钟）
FETCH_INTERVAL_MINUTES=15

# 提醒发送间隔（分钟）
REMINDER_INTERVAL_MINUTES=30

# 单次提醒最大条数
REMINDER_MAX_PER_BATCH=10

# 两次对同一条消息提醒的最小间隔（小时）
REMINDER_COOLDOWN_HOURS=4

# ============================================================
# Web Dashboard 配置
# ============================================================
WEB_HOST=0.0.0.0
WEB_PORT=8000
# 简单的 API Key 认证（生产环境建议使用 OAuth）
WEB_API_KEY=your-secret-api-key

# ============================================================
# 日志级别
# ============================================================
LOG_LEVEL=INFO
