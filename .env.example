# ============================================================
# LLM 配置（支持 OpenAI 兼容接口）
# ============================================================
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# ============================================================
# Lark (Feishu) 应用凭证
# 在飞书开放平台 https://open.feishu.cn 创建企业自建应用后获取
# 需要开通权限：im:message:readonly, im:chat:readonly, im:message
# ============================================================
LARK_APP_ID=cli_xxxxxxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 域名类型："lark"（海外，默认）或 "feishu"（国内）
LARK_DOMAIN_TYPE=lark

# 被监控用户的 open_id（系统会识别与此用户相关的消息）
LARK_TARGET_USER_ID=ou_xxxxxxxxxxxxxxxx

# 需要监控的群组 chat_id 列表（逗号分隔，留空则监控所有已加入的群）
LARK_MONITORED_CHATS=

# ============================================================
# Telegram 配置（User API / MTProto）
# 注意：使用你自己的手机号登录，不是 Bot API！
# 前往 https://my.telegram.org 创建应用获取 api_id 和 api_hash
# ============================================================
TG_API_ID=12345678
TG_API_HASH=abcdef1234567890abcdef1234567890
TG_PHONE=+8613800138000

# Session 文件名（保存在 data/ 目录下，首次登录后自动生成）
TG_SESSION_NAME=tg_user_session

# 需要监控的 Telegram 对话 ID 列表（逗号分隔，留空则监控所有对话）
# 可通过 `python scripts/tg_login.py` 查看所有对话 ID
TG_MONITORED_CHATS=-1001234567890,-1009876543210

# ============================================================
# WhatsApp 配置（暂缓）
# ============================================================
# WA_API_TOKEN=
# WA_PHONE_NUMBER_ID=
# WA_TARGET_PHONE=

# ============================================================
# 数据库配置
# Railway 部署必须用 MySQL（容器重启后 SQLite 文件会丢失）
# 在 Railway Dashboard 新建一个 MySQL 服务，把连接串填到这里
# ============================================================
# Railway MySQL（生产环境，必须）
DATABASE_URL=mysql+pymysql://root:password@mysql.railway.internal:3306/railway

# SQLite（仅本地开发用，Railway 上不要用）
# DATABASE_URL=sqlite:///data/msg_reminder.db

# ============================================================
# 调度配置
# ============================================================
# 消息拉取间隔（分钟）
FETCH_INTERVAL_MINUTES=15

# 提醒发送间隔（分钟）
REMINDER_INTERVAL_MINUTES=30

# 单次提醒最大条数
REMINDER_MAX_PER_BATCH=10

# 两次对同一条消息提醒的最小间隔（小时）
REMINDER_COOLDOWN_HOURS=4

# ============================================================
# Web Dashboard 配置
# ============================================================
WEB_HOST=0.0.0.0
WEB_PORT=8000
# 简单的 API Key 认证（生产环境建议使用 OAuth）
WEB_API_KEY=your-secret-api-key

# ============================================================
# 日志级别
# ============================================================
LOG_LEVEL=INFO
